{
  "expo": {
    "name": "LocalMP3App",
    "slug": "LocalMP3App",
    "version": "1.0.0",
    "owner": "akash_1705",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.akash.localmp3app",
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "android": {
            "foregroundService": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1964a7f4-802b-4d48-940b-35d86e101748"
      }
    }
  }
}